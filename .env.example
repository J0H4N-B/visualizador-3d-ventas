# ── Configuración de entorno ──────────────────────────────
# Copia este archivo como .env y ajusta los valores.

# Clave secreta de Flask (cámbiala en producción por algo aleatorio)
SECRET_KEY=cambia-esta-clave-en-produccion

# Tamaño máximo de archivo permitido para subir (en bytes)
# 5MB por defecto
MAX_CONTENT_LENGTH=5242880

# Carpeta donde se guardan los CSV subidos (relativa a la raíz del proyecto)
UPLOAD_FOLDER=data/uploads

# Modo de Flask: development | production
FLASK_ENV=development
